rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isStr(v, min, max) {
      return v is string && v.size() >= min && v.size() <= max;
    }
    function isSport(v) {
      return v in ['baseball', 'softball', 'kickball'];
    }
    function isStatus(v) {
      return v in ['in_progress', 'completed'];
    }
    function isMaxInnings(v) {
      return v is int && v >= 1 && v <= 30;
    }
    function isDate(v) {
      return v is string && v.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }
    function isInningList(v) {
      return v is list && v.size() <= 20;
    }

    function gameKeysOk(data) {
      return data.keys().hasOnly([
        'sport','date','location','team_top','team_bottom',
        'max_innings','innings','status','created_at','updated_at','view_token','owner_uid'
      ]) && data.keys().hasAll([
        'sport','date','location','team_top','team_bottom',
        'max_innings','innings','status','created_at','updated_at'
      ]);
    }

    function validGameShape(data) {
      return isSport(data.sport)
        && isDate(data.date)
        && data.location is string && data.location.size() <= 100
        && isStr(data.team_top, 1, 50)
        && isStr(data.team_bottom, 1, 50)
        && isMaxInnings(data.max_innings)
        && isInningList(data.innings)
        && isStatus(data.status)
        && data.created_at is timestamp
        && data.updated_at is timestamp
        && (!data.keys().hasAny(['view_token']) || (data.view_token is string && data.view_token.size() > 0))
        && (!data.keys().hasAny(['owner_uid']) || (data.owner_uid is string && data.owner_uid.size() > 0));
    }

    match /games/{gameId} {
      allow read: if true;

      allow create: if gameKeysOk(request.resource.data)
        && validGameShape(request.resource.data)
        && request.resource.data.created_at == request.time
        && request.resource.data.updated_at == request.time
        && request.resource.data.innings.size() == 0
        && request.resource.data.status == 'in_progress';

      allow update: if gameKeysOk(request.resource.data)
        && validGameShape(request.resource.data)
        && request.resource.data.created_at == resource.data.created_at
        && request.resource.data.updated_at == request.time
        && (
          !('updated_at' in resource.data.keys())
          || request.resource.data.updated_at > resource.data.updated_at
        );

      allow delete: if true;
    }

    match /view_tokens/{viewToken} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['game_id'])
        && request.resource.data.game_id is string
        && request.resource.data.game_id.size() > 0;
      allow update: if false;
      allow delete: if true;
    }

    // Recovery key identities — written exclusively by Firebase Admin (server-side API routes).
    // Client can only read their own identity document.
    match /identities/{identityId} {
      allow read: if request.auth != null
        && resource.data.firebase_uid == request.auth.uid;
      allow write: if false; // Admin SDK bypasses these rules
    }
  }
}
