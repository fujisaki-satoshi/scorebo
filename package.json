{
  "name": "scorebo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "capture-screens": "node --env-file=.env.local scripts/capture-landing-screens.mjs",
    "export-profile": "node --env-file=.env.local scripts/export-profile-png.mjs",
    "record-demo": "node --env-file=.env.local scripts/record-demo.mjs",
    "reset-with-sample": "node --env-file=.env.local scripts/reset-with-sample.mjs",
    "seed-games": "node --env-file=.env.local scripts/seed-games.mjs",
    "deploy:firestore": "npx firebase-tools deploy --only firestore",
    "prepare": "husky",
    "test:unit": "vitest run tests/logic.unit.test.ts",
    "test:rules": "firebase emulators:exec --only firestore 'vitest run tests/firestore.rules.test.ts'",
    "test:e2e": "firebase emulators:exec --only firestore 'playwright test'",
    "test:fast": "npm run test:unit && npm run test:rules",
    "test": "npm run test:fast && npm run test:e2e"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^4.3.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.10.0",
    "next": "16.2.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "firebase-tools": "^15.17.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
